---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { servicesData } from '../../data/services';

export function getStaticPaths() {
  const entries = Object.entries(servicesData);
  return entries.map(([slug, service]) => ({
    params: { slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<BaseLayout
  title={service.title}
  description={service.description}
>
  <section class="service-detail section">
    <div class="container container--md">
      <!-- Header -->
      <div class="service-detail__header reveal">
        <a class="service-detail__back" href="/services">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          All Services
        </a>
        <p class="section-header__label">{service.title}</p>
        <h1 class="service-detail__title">{service.headline}</h1>
        <p class="service-detail__overview">{service.overview}</p>
      </div>

      <!-- Benefits -->
      <div class="service-detail__section reveal">
        <h2>Key Benefits</h2>
        <ul class="service-detail__benefits">
          {service.benefits.map((benefit: string) => (
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>{benefit}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Process -->
      <div class="service-detail__section reveal">
        <h2>My Process</h2>
        <div class="service-detail__process">
          {service.process.map((step: string, i: number) => (
            <div class="service-detail__step">
              <span class="service-detail__step-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="service-detail__step-label">{step}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Technologies -->
      <div class="service-detail__section reveal">
        <h2>Technologies</h2>
        <div class="service-detail__tech">
          {service.technologies.map((tech: string) => (
            <span class="chip">{tech}</span>
          ))}
        </div>
      </div>

      <!-- Industries -->
      {service.industries.length > 0 && service.industries[0] !== 'All industries' && service.industries[0] !== 'All industries using Odoo ERP' && (
        <div class="service-detail__section reveal">
          <h2>Industries Served</h2>
          <div class="service-detail__tech">
            {service.industries.map((ind: string) => (
              <span class="chip">{ind}</span>
            ))}
          </div>
        </div>
      )}

      <!-- FAQ -->
      <div class="service-detail__section reveal">
        <h2>Frequently Asked Questions</h2>
        <div class="service-detail__faqs">
          {service.faqs.map((faq: { q: string; a: string }) => (
            <details class="service-detail__faq">
              <summary>{faq.q}</summary>
              <p>{faq.a}</p>
            </details>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="service-detail__cta reveal">
        <div class="card" style="text-align:center; padding: var(--space-10); background: var(--color-accent-soft); border-color: var(--color-accent-border);">
          <h2 style="margin-bottom: var(--space-3);">Interested in {service.title}?</h2>
          <p style="color: var(--color-text-tertiary); margin-bottom: var(--space-6); max-width: 440px; margin-inline: auto;">
            Every project is custom-quoted based on your specific requirements. Let's discuss yours.
          </p>
          <a class="btn btn--primary btn--lg" href="/contact">Contact for Quote</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .service-detail { padding-top: calc(72px + var(--space-16)); }

  .service-detail__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-6);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .service-detail__back:hover { color: var(--color-accent); }

  .service-detail__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    margin-bottom: var(--space-6);
  }

  .service-detail__overview {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  .service-detail__section { margin-top: var(--space-16); }

  .service-detail__section h2 {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-accent);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-6);
  }

  .service-detail__benefits {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .service-detail__benefits li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .service-detail__benefits svg {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .service-detail__process {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-4);
  }

  .service-detail__step {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-bg-secondary);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .service-detail__step:hover { border-color: var(--color-border-hover); }

  .service-detail__step-num {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .service-detail__step-label {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .service-detail__tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .service-detail__faqs {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .service-detail__faq {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .service-detail__faq[open] { border-color: var(--color-accent-border); }

  .service-detail__faq summary {
    padding: var(--space-4) var(--space-5);
    font-weight: 600;
    font-size: var(--text-base);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .service-detail__faq summary:hover { background: var(--color-bg-secondary); }
  .service-detail__faq summary::-webkit-details-marker { display: none; }

  .service-detail__faq summary::after {
    content: '+';
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    font-weight: 300;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .service-detail__faq[open] summary::after {
    transform: rotate(45deg);
    color: var(--color-accent);
  }

  .service-detail__faq p {
    padding: 0 var(--space-5) var(--space-5);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  .service-detail__cta { margin-top: var(--space-16); }
</style>
