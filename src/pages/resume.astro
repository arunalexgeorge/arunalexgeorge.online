---
import BaseLayout from '../layouts/BaseLayout.astro';

const resumeData = {
  name: 'Arun Alex George',
  title: 'ERP Consultant · Solution Architect · Technical Lead',
  email: 'hello@arunalexgeorge.online',
  location: 'Kochi, Kerala, India',
  website: 'arunalexgeorge.online',
  linkedin: 'linkedin.com/in/arunageorge',
  github: 'github.com/arunalexgeorge',
  languages: ['English', 'Malayalam', 'Hindi (Basic)', 'Tamil (Basic)'],
  summary: 'Results-driven ERP Consultant and Technical Lead with 8+ years of experience in enterprise software development and 20+ successful ERP implementations. Specialized in Odoo ERP development, customization, and business process optimization across manufacturing, healthcare, retail, and finance verticals. Published 20+ Odoo apps and 3 themes on the official Odoo App Store. Proven track record of leading development teams, managing client relationships, and delivering complex technology projects on time and within budget.',
};

const experience = [
  { period: 'Jun 2022 — Present', title: 'Senior Odoo Developer & Team Lead', company: 'Ideenkreise Tech Pvt Ltd, Kochi', highlights: ['Lead a team of 5-6 developers across multiple ERP projects', 'Architected and delivered 20+ Odoo ERP implementations', 'Managed 50+ client relationships and project lifecycles', 'Published 20+ apps and 3 themes on the Odoo App Store', 'Conduct client training and change management programs'] },
  { period: 'Jun 2021 — May 2022', title: 'Odoo Developer', company: 'Ideenkreise Tech Pvt Ltd, Kochi', highlights: ['Built custom Odoo modules for manufacturing and retail', 'Implemented Purchase, Accounting, Sales, and Inventory workflows', 'Developed e-invoicing and bidding portal integrations'] },
  { period: 'Jun 2020 — May 2021', title: 'PHP Developer', company: 'Ideenkreise Tech Pvt Ltd, Kochi', highlights: ['Developed CRM systems and hotel booking platforms', 'Built REST APIs and WordPress e-commerce sites'] },
  { period: 'Oct 2018 — May 2020', title: 'PHP Developer → Senior PHP Developer', company: 'Wahylab Solutions, Kochi', highlights: ['Started as Trainee, promoted to Senior Developer', 'Built web applications with PHP, CodeIgniter, WordPress', 'Mentored junior developers'] },
];

const skills = {
  'ERP & Frameworks': ['Odoo ERP (v10–v19)', 'CodeIgniter', 'WordPress'],
  'Languages': ['Python', 'PHP', 'JavaScript', 'HTML/CSS', 'SQL'],
  'Databases': ['PostgreSQL', 'MySQL'],
  'Cloud & DevOps': ['AWS', 'DigitalOcean', 'Docker', 'Nginx', 'Linux'],
  'Tools': ['Git', 'Jira', 'Odoo PMS', 'REST API Design'],
};
---

<BaseLayout
  title="Resume"
  description="Interactive resume of Arun Alex George — ERP Consultant, Solution Architect & Technical Lead with 8+ years of experience."
>
  <section class="resume-page section">
    <div class="container container--md">
      <div class="section-header reveal">
        <p class="section-header__label">Resume</p>
        <h1 class="section-header__title">{resumeData.name}</h1>
        <p class="resume-title">{resumeData.title}</p>
      </div>

      <!-- Contact Bar -->
      <div class="resume-contact reveal">
        <span>{resumeData.email}</span>
        <span class="resume-contact__sep">·</span>
        <span>{resumeData.location}</span>
        <span class="resume-contact__sep">·</span>
        <span>{resumeData.website}</span>
      </div>

      <!-- Summary -->
      <div class="resume-section reveal">
        <h2 class="resume-section__title">Professional Summary</h2>
        <p class="resume-section__text">{resumeData.summary}</p>
      </div>

      <!-- Experience -->
      <div class="resume-section reveal">
        <h2 class="resume-section__title">Professional Experience</h2>
        {experience.map((job) => (
          <div class="resume-job">
            <div class="resume-job__header">
              <div>
                <h3 class="resume-job__title">{job.title}</h3>
                <p class="resume-job__company">{job.company}</p>
              </div>
              <span class="resume-job__period">{job.period}</span>
            </div>
            <ul class="resume-job__list">
              {job.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Skills -->
      <div class="resume-section reveal">
        <h2 class="resume-section__title">Technical Skills</h2>
        <div class="resume-skills">
          {Object.entries(skills).map(([category, items]) => (
            <div class="resume-skill-group">
              <h4 class="resume-skill-group__title">{category}</h4>
              <div class="resume-skill-group__items">
                {items.map((item) => (
                  <span class="chip">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Education -->
      <div class="resume-section reveal">
        <h2 class="resume-section__title">Education</h2>
        <div class="resume-job">
          <div class="resume-job__header">
            <div>
              <h3 class="resume-job__title">B.E. Computer Science & Engineering</h3>
              <p class="resume-job__company">Hindusthan College of Engineering & Technology (Anna University)</p>
            </div>
            <span class="resume-job__period">2018</span>
          </div>
        </div>
        <div class="resume-job">
          <div class="resume-job__header">
            <div>
              <h3 class="resume-job__title">Diploma in Computer Science & Engineering</h3>
              <p class="resume-job__company">Karpagam Polytechnic College, Coimbatore</p>
            </div>
            <span class="resume-job__period">2014</span>
          </div>
        </div>
      </div>

      <!-- Languages -->
      <div class="resume-section reveal">
        <h2 class="resume-section__title">Languages</h2>
        <div class="resume-skill-group__items">
          {resumeData.languages.map((lang) => (
            <span class="chip">{lang}</span>
          ))}
        </div>
      </div>

      <!-- Download -->
      <div class="resume-download reveal">
        <a class="btn btn--primary btn--lg" href="/resume.pdf" target="_blank">
          Download PDF Resume
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .resume-page { padding-top: calc(72px + var(--space-16)); }

  .resume-title {
    text-align: center;
    color: var(--color-accent);
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .resume-contact {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .resume-contact__sep {
    color: var(--color-text-muted);
  }

  .resume-section {
    margin-bottom: var(--space-10);
  }

  .resume-section__title {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-accent);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-6);
  }

  .resume-section__text {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  .resume-job {
    margin-bottom: var(--space-6);
  }

  .resume-job__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .resume-job__title {
    font-size: var(--text-base);
    font-weight: 600;
  }

  .resume-job__company {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-top: var(--space-1);
  }

  .resume-job__period {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    white-space: nowrap;
    font-family: var(--font-display);
  }

  .resume-job__list {
    list-style: disc;
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .resume-job__list li {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .resume-skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-6);
  }

  .resume-skill-group__title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .resume-skill-group__items {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .resume-download {
    text-align: center;
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .resume-job__header {
      flex-direction: column;
    }
  }
</style>
