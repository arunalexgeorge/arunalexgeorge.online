const products = [
  // ── Themes (3) ──────────────────────────────────────────────────
  { name: 'Web Responsive Enterprise', desc: 'Odoo 19 Enterprise look & feel and responsive UX for Community Edition (light mode).', price: 'FREE', downloads: 55, category: 'Theme', version: '19.0', href: 'https://apps.odoo.com/apps/themes/19.0/web_responsive_enterprise' },
