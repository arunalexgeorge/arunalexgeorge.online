---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Blog"
  description="Insights on Odoo ERP, business automation, AI in enterprise, cloud architecture, and best practices by Arun Alex George."
>
  <section class="blog-page section">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-header__label">Insights</p>
        <h1 class="section-header__title">Blog & Articles</h1>
        <p class="section-header__desc">
          Thoughts on ERP best practices, Odoo tutorials, AI in enterprise,
          and business automation.
        </p>
      </div>

      <div class="blog-coming-soon reveal">
        <div class="blog-coming-soon__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </div>
        <h2>Coming Soon</h2>
        <p>
          I'm working on detailed articles about Odoo development, ERP implementation
          strategies, and AI-powered business automation. Check back soon!
        </p>
        <p class="blog-coming-soon__medium">
          In the meantime, read my articles on
          <a href="https://medium.com/@arunalexgeorge" target="_blank" rel="noopener noreferrer">
            Medium →
          </a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-page { padding-top: calc(72px + var(--space-16)); }

  .blog-coming-soon {
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    padding: var(--space-16) var(--space-8);
  }

  .blog-coming-soon__icon {
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  .blog-coming-soon h2 {
    margin-bottom: var(--space-4);
  }

  .blog-coming-soon p {
    color: var(--color-text-tertiary);
    line-height: var(--leading-relaxed);
  }

  .blog-coming-soon__medium {
    margin-top: var(--space-6);
  }

  .blog-coming-soon__medium a {
    color: var(--color-accent);
    font-weight: 600;
  }
</style>
